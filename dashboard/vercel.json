{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "installCommand": "npm install",
  "framework": null,
  "crons": [
    {
      "path": "/api/ceo/run",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/gtd/process",
      "schedule": "0 8 * * *"
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
